<link rel="stylesheet" href="/style.css">
<%- include("partials/navbar") %>
<div class="container">

  <h1>Edit Review</h1>

  <form method="POST" action="/restaurants/<%= restaurant.id %>/update">
    method="POST"
  >
    <div class="mb-3">
      <label for="name" class="form-label">Restaurant Name</label>
      <input type="text" class="form-control" id="name" name="name" value="<%= restaurant.name %>" required>
    </div>

    <div class="mb-3">
      <label for="cuisine" class="form-label">Cuisine</label>
      <input type="text" class="form-control" id="cuisine" name="cuisine" value="<%= restaurant.cuisine %>" required>
    </div>

    <div class="mb-3">
      <label for="rating" class="form-label">Rating (1-5)</label>
      <input type="number" class="form-control" id="rating" name="rating" min="1" max="5" value="<%= restaurant.rating %>" required>
    </div>

    <div class="mb-3">
      <label for="bestFood" class="form-label">Best Food</label>
      <input type="text" class="form-control" id="bestFood" name="bestFood" value="<%= restaurant.bestFood %>" required>
    </div>

    <div class="mb-3">
      <label for="review" class="form-label">Review</label>
      <textarea class="form-control" id="review" name="review" rows="3" required><%= restaurant.review %></textarea>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
  </form>
</div>